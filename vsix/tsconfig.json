{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "paths": {
      "../src/*": ["../src/*"]
    }
  },
  "include": ["src/**/*.ts", "../src/domain/**/*.ts", "../src/services/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
